# Адреса вашого сайту (потрібна для створення посилання на підтвердження реєстрації)
APP_URL=http://localhost:3000

# Налаштування SMTP сервера для відправки листів
# Для Gmail: smtp.gmail.com
# Для Ukr.net: smtp.ukr.net
SMTP_HOST=smtp.gmail.com

# Порт: 587 (для STARTTLS) або 465 (для SSL/TLS)
SMTP_PORT=587

# true для порту 465, false для 587
SMTP_SECURE=false

# Ваша електронна пошта на поштовому сервері
SMTP_USER=your-email@gmail.com

# Пароль додатку (App Password), згенерований у налаштуваннях безпеки вашого акаунту
# Увага: для Gmail або Ukr.net потрібно створити спеціальний "Пароль додатку", стандартний пароль не підійде!
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# Від кого надсилається лист (Sender display name)
SMTP_FROM="KRONA Store" <your-email@gmail.com>
